generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String               @id @default(cuid())
  slug               String               @unique
  name               String
  status             String               @default("active")
  nerisEntityId      String?
  /// Fire Recovery USA Recovery Hub subscription key (non-secret identifier; store API password in env).
  fireRecoverySubscriptionKey   String?
  /// Department display name sent to Fire Recovery incident billing API.
  fireRecoveryDepartmentName    String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  domains            TenantDomain[]
  users              User[]
  departments        DepartmentDetails[]
  incidents          Incident[]
  cadEmails               CadEmailIngest[]
  cadParsingSettings      CadParsingSettings?
  cadEmailAllowlist       CadEmailAllowlistEntry[]
  nerisExportHistory      NerisExportHistory[]
  nerisDrafts             NerisDraft[]
  fireRecoveryIncidentBillings FireRecoveryIncidentBilling[]
}

/// One row per incident call number per tenant: Fire Recovery billing submit + cached billing status.
model FireRecoveryIncidentBilling {
  id                    String    @id @default(cuid())
  tenantId              String
  callNumber            String
  trackingId            String?
  lastSubmitAt          DateTime?
  lastSubmitOk          Boolean   @default(false)
  lastSubmitError       String    @default("")
  incidentType          String    @default("")
  incidentDateLabel     String    @default("")
  invoiceId             String    @default("")
  invoiceAmount         String    @default("")
  invoiceAmountDue      String    @default("")
  invoiceSubmitDate     String    @default("")
  invoiceStatus         String    @default("")
  lastPaymentDate       String    @default("")
  lastPaymentAmount     String    @default("")
  paymentPlan           Boolean   @default(false)
  billingFetchedAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, callNumber])
  @@index([tenantId])
  @@index([tenantId, updatedAt])
}

model TenantDomain {
  id        String   @id @default(cuid())
  tenantId  String
  hostname  String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  username     String
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, username])
  @@index([tenantId])
}

model DepartmentDetails {
  id             String   @id @default(cuid())
  tenantId       String
  departmentName String?
  payloadJson    Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
  @@index([tenantId])
}

model ScheduleAssignments {
  id              String   @id @default(cuid())
  tenantId        String
  shiftType       String
  dateKey         String
  assignmentsJson Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, shiftType, dateKey])
  @@index([tenantId])
}

model Incident {
  id             String    @id @default(cuid())
  tenantId       String
  incidentNumber String?
  dispatchNumber String?
  incidentType   String    @default("")
  priority       String    @default("")
  address        String    @default("")
  stillDistrict  String    @default("")
  assignedUnits  String    @default("")
  reportedBy     String?
  callbackNumber String?
  dispatchNotes  String?
  currentState   String    @default("Draft")
  receivedAt     String    @default("")
  dispatchInfo   String    @default("")
  apparatusJson  Json?
  mapReference   String?
  deletedAt      DateTime?
  deletedBy      String?
  deletedReason  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model CadEmailIngest {
  id                 String   @id @default(cuid())
  tenantId           String?
  fromAddress        String   @default("")
  toAddress          String   @default("")
  rawBody            String   @default("")
  headersJson        Json?
  /// Output of message rules at ingest (Batch H); empty if no rules / failure.
  parsedMessageText  String   @default("")
  createdAt          DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([createdAt])
}

/// Per-tenant CAD dispatch parsing config (message + incident rule JSON; Batch C+).
model CadParsingSettings {
  id                         String   @id @default(cuid())
  tenantId                   String   @unique
  enableIncidentCreation     Boolean  @default(false)
  messageRulesJson           Json     @default("[]")
  incidentRulesJson          Json     @default("[]")
  incidentFieldMapJson       Json     @default("{}")
  incidentNumberExtractJson  Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Per-tenant allowed sender patterns for CAD email (enforced in Batch D).
model CadEmailAllowlistEntry {
  id          String   @id @default(cuid())
  tenantId    String
  pattern     String
  patternType String   @default("domain_suffix")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, enabled])
}

model NerisExportHistory {
  id                       String   @id @default(cuid())
  tenantId                 String
  callNumber               String   @default("")
  incidentType             String   @default("")
  address                  String   @default("")
  exportedAtIso            String   @default("")
  exportedAtLabel          String   @default("")
  attemptStatus            String   @default("success")
  httpStatus               Int      @default(200)
  httpStatusText           String   @default("")
  statusLabel              String   @default("")
  reportStatusAtExport     String   @default("")
  validatorName            String   @default("")
  reportWriterName         String   @default("")
  submittedEntityId        String   @default("")
  submittedDepartmentNerisId String @default("")
  nerisId                  String   @default("")
  responseSummary          String   @default("")
  responseDetail           String   @default("")
  submittedPayloadPreview  String   @default("")
  createdAt                DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model NerisDraft {
  id         String   @id @default(cuid())
  tenantId   String
  callNumber String
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, callNumber])
  @@index([tenantId])
}