generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String               @id @default(cuid())
  slug               String               @unique
  name               String
  status             String               @default("active")
  nerisEntityId      String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  domains            TenantDomain[]
  users              User[]
  departments        DepartmentDetails[]
  incidents          Incident[]
  cadEmails          CadEmailIngest[]
  nerisExportHistory NerisExportHistory[]
  nerisDrafts        NerisDraft[]
}

model TenantDomain {
  id        String   @id @default(cuid())
  tenantId  String
  hostname  String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  username     String
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, username])
  @@index([tenantId])
}

model DepartmentDetails {
  id             String   @id @default(cuid())
  tenantId       String
  departmentName String?
  payloadJson    Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
  @@index([tenantId])
}

model ScheduleAssignments {
  id              String   @id @default(cuid())
  tenantId        String
  shiftType       String
  dateKey         String
  assignmentsJson Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, shiftType, dateKey])
  @@index([tenantId])
}

model Incident {
  id             String    @id @default(cuid())
  tenantId       String
  incidentNumber String?
  dispatchNumber String?
  incidentType   String    @default("")
  priority       String    @default("")
  address        String    @default("")
  stillDistrict  String    @default("")
  assignedUnits  String    @default("")
  reportedBy     String?
  callbackNumber String?
  dispatchNotes  String?
  currentState   String    @default("Draft")
  receivedAt     String    @default("")
  dispatchInfo   String    @default("")
  apparatusJson  Json?
  mapReference   String?
  deletedAt      DateTime?
  deletedBy      String?
  deletedReason  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model CadEmailIngest {
  id          String   @id @default(cuid())
  tenantId    String?
  fromAddress String   @default("")
  toAddress   String   @default("")
  rawBody     String   @default("")
  headersJson Json?
  createdAt   DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([createdAt])
}

model NerisExportHistory {
  id                       String   @id @default(cuid())
  tenantId                 String
  callNumber               String   @default("")
  incidentType             String   @default("")
  address                  String   @default("")
  exportedAtIso            String   @default("")
  exportedAtLabel          String   @default("")
  attemptStatus            String   @default("success")
  httpStatus               Int      @default(200)
  httpStatusText           String   @default("")
  statusLabel              String   @default("")
  reportStatusAtExport     String   @default("")
  validatorName            String   @default("")
  reportWriterName         String   @default("")
  submittedEntityId        String   @default("")
  submittedDepartmentNerisId String @default("")
  nerisId                  String   @default("")
  responseSummary          String   @default("")
  responseDetail           String   @default("")
  submittedPayloadPreview  String   @default("")
  createdAt                DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model NerisDraft {
  id         String   @id @default(cuid())
  tenantId   String
  callNumber String
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, callNumber])
  @@index([tenantId])
}