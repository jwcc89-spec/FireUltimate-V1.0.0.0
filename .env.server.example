# Server-side NERIS proxy configuration
# Copy to .env.server and fill with your NERIS vendor account values.

# Proxy server port
NERIS_PROXY_PORT=8787

# NERIS OpenAPI defaults
# For most integration testing, use api-test.
# Production URL (when authorized): https://api.neris.fsri.org/v1
NERIS_BASE_URL=https://api-test.neris.fsri.org/v1
# Recommended for vendor integrations:
NERIS_GRANT_TYPE=client_credentials
# Optional token scope if provided by NERIS:
NERIS_TOKEN_SCOPE=

# Required for incident create endpoint path: /incident/{neris_id_entity}
NERIS_ENTITY_ID=

# Optional fallback if report field "Department NERIS ID" is empty
NERIS_DEPARTMENT_NERIS_ID=

# Auth option A (recommended): OAuth password flow
# (Only needed when NERIS_GRANT_TYPE=password)
NERIS_CLIENT_ID=
NERIS_CLIENT_SECRET=
NERIS_USERNAME=
NERIS_PASSWORD=

# Auth option B (alternative): fixed access token
# If provided, proxy skips /token call and uses this bearer token directly.
NERIS_STATIC_ACCESS_TOKEN=

# Optional location fallback defaults when report location values are missing
NERIS_DEFAULT_STATE=IL
NERIS_DEFAULT_COUNTRY=US

# DB URL — PostgreSQL (e.g. Neon). If using SSL, prefer ?sslmode=verify-full to avoid pg security warnings.
DATABASE_URL=

# Platform admin: required for POST /api/admin/tenants and /api/admin/tenants/:id/domains
# Send X-Platform-Admin-Key or Authorization: Bearer <value> on admin requests
PLATFORM_ADMIN_KEY=

# CAD email ingest (Cloudflare Worker → POST /api/cad/inbound-email)
# When NODE_ENV=production (Render staging and production both often use this), the API requires
# CAD_INGEST_SECRET and the Worker must send the same value as header X-CAD-Ingest-Secret.
# For local dev without NODE_ENV=production, leave unset to allow ingest without the header.
# CAD_INGEST_SECRET=